<mvc:View controllerName="com.test.cvamenares.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <content>
            <HBox class="sapUiMediumMargin">

                <!-- Columna izquierda -->
                <VBox width="400px" class="sapUiSmallMarginEnd">

                    <!-- Panel Contacto -->
                    <Panel id="infoPanel_resumen" headerText="Datos Contacto" class="sapUiSmallMarginBottom">
                        <Text text="{/resumen}" class="sapUiSmallMargin"/>
                    </Panel>

                    <!-- Fila 1: 2 tiles -->
                    <HBox justifyContent="Start" wrap="Wrap" class="sapUiSmallMarginBottom">
                        <GenericTile header="Resumen Profesional" subheader="Resumen"
                            frameType="TwoByHalf" press=".onBotonPress" data:key="res_prof"
                            xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                            <TileContent>
                                <ImageContent src="sap-icon://activity-individual"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile header="FORTALEZAS" subheader=""
                            frameType="TwoByHalf" press=".onBotonPress" data:key="habilidades"
                            xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
                            class="sapUiSmallMarginBottom">
                            <TileContent>
                                <ImageContent src="sap-icon://learning-assistant"/>
                            </TileContent>
                        </GenericTile>
                    </HBox>

                    <!-- Fila 2: 3 tiles -->
                    <HBox justifyContent="Start" wrap="Wrap" class="sapUiSmallMarginBottom">
                        <GenericTile header="Certificaciones" subheader="Educación"
                            frameType="TwoByHalf" press=".onBotonPress" data:key="educacion"
                            xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                            <TileContent>
                                <ImageContent src="sap-icon://contacts"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile header="Historial laboral" subheader="Trayectoria"
                            frameType="TwoByHalf" press=".onBotonPress" data:key="experiencia"
                            xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
                            class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                            <TileContent>
                                <ImageContent src="sap-icon://education"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile header="Referencias" subheader="Contactos"
                            frameType="TwoByHalf" press=".onBotonPress" data:key="contactos"
                            xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
                            class="sapUiSmallMarginBottom">
                            <TileContent>
                                <ImageContent src="sap-icon://person-placeholder"/>
                            </TileContent>
                        </GenericTile>
                    </HBox>

                </VBox>

                <!-- Columna derecha: Panel contenido -->
                <VBox width="600px">
                    <Panel id="infoPanel" headerText="{/titulo}" height="500px">
                        <Text text="{/contenido}" class="sapUiSmallMargin"/>
                    </Panel>
                </VBox>

            </HBox>
        </content>
    </Page>
</mvc:View>